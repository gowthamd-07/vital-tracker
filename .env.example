# ──────────────────────────────────────────────────────────────────
# VitalTrack — environment variables
# Copy this file to .env.local and fill in the values.
# ──────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# Neon (production / remote dev):
#   Get the pooled connection string from https://console.neon.tech
# Docker (local):
#   docker compose up -d
#   DATABASE_URL="postgresql://tracker:tracker@localhost:5432/tracker"
DATABASE_URL="postgresql://tracker:tracker@localhost:5432/tracker"

# ── Auth ──────────────────────────────────────────────────────────
# Generate a secret:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Your app URL. On Vercel this is set automatically; for local dev:
AUTH_URL="http://localhost:3000"
